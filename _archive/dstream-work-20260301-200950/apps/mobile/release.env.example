# Mobile store release environment template (do not commit real secrets).
# Usage:
#   cp apps/mobile/release.env.example apps/mobile/release.env
#   edit values
#   MOBILE_RELEASE_ENV_FILE=apps/mobile/release.env npm run mobile:release:ios:testflight

# ---------- Shared ----------
IOS_APP_IDENTIFIER=stream.dstream
ANDROID_APPLICATION_ID=stream.dstream

# ---------- iOS / App Store Connect ----------
APPLE_ID=
APPLE_DEVELOPER_TEAM_ID=
APP_STORE_CONNECT_TEAM_ID=
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Option A: path to AuthKey_XXXXXX.p8
APP_STORE_CONNECT_API_KEY_PATH=
# Option B: literal p8 content (single-line escaped)
APP_STORE_CONNECT_API_KEY=

# iOS lane toggles
IOS_WAIT_FOR_BUILD_PROCESSING=0
IOS_DISTRIBUTE_EXTERNAL=0
IOS_TESTFLIGHT_GROUPS=
IOS_SUBMIT_FOR_REVIEW=0
IOS_AUTOMATIC_RELEASE=0

# ---------- Android / Google Play ----------
ANDROID_PLAY_JSON_KEY_PATH=
ANDROID_KEYSTORE_PATH=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=

# Optional version overrides
ANDROID_VERSION_CODE=
ANDROID_VERSION_NAME=
ANDROID_RELEASE_STATUS=completed
